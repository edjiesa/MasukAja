<%- include('partials/header') %>

<div class="w-full max-w-6xl w-full mx-auto space-y-8">
    <div class="glass-panel p-8 rounded-2xl shadow-xl flex flex-col md:flex-row items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-white">Welcome back, <span class="text-primary"><%= user %></span>!</h1>
            <p class="text-slate-400 mt-2">Manage your securely stored passwords.</p>
        </div>
        <div class="mt-4 md:mt-0">
            <button onclick="document.getElementById('addPasswordModal').classList.remove('hidden')" 
                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-lg shadow-primary/30 text-white bg-primary hover:bg-primaryHover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-900 focus:ring-primary transition-colors">
                <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Add New Password
            </button>
        </div>
    </div>

    <!-- Passwords List -->
    <div class="glass-panel rounded-2xl shadow-xl overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-700">
            <h3 class="text-lg leading-6 font-medium text-white">Your Vault</h3>
        </div>
        
        <% if (passwords && passwords.length > 0) { %>
            <ul class="divide-y divide-slate-700/50">
                <% passwords.forEach(pwd => { %>
                    <li class="px-6 py-5 hover:bg-slate-800/30 transition-colors">
                        <div class="flex items-center justify-between">
                            <div class="flex flex-col">
                                <p class="text-lg font-semibold text-white truncate flex items-center gap-2">
                                    <span class="w-8 h-8 rounded bg-slate-700 flex items-center justify-center text-sm font-bold text-slate-300">
                                        <%= pwd.app_name.charAt(0).toUpperCase() %>
                                    </span>
                                    <%= pwd.app_name %>
                                </p>
                                <p class="text-sm text-slate-400 mt-1 flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                    <%= pwd.app_username %>
                                </p>
                            </div>
                            <div class="flex items-center space-x-4">
                                <div class="relative flex items-center group">
                                    <input type="password" value="<%= pwd.app_password %>" readonly
                                        class="bg-slate-900 border border-slate-700 rounded px-3 py-1 text-slate-300 text-sm focus:outline-none w-32 md:w-48"
                                        id="pwd-<%= pwd.id %>">
                                    <button onclick="togglePassword('pwd-<%= pwd.id %>')" 
                                        class="ml-2 text-slate-400 hover:text-white transition-colors" title="Toggle visibility">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </button>
                                </div>
                                <form action="<%= baseUrl %>/passwords/delete/<%= pwd.id %>" method="POST" class="inline">
                                    <button type="submit" onclick="return confirm('Are you sure you want to delete this password?')"
                                        class="text-red-400 hover:text-red-300 p-2 rounded-full hover:bg-red-400/10 transition-colors" title="Delete">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <div class="p-10 text-center">
                <svg class="mx-auto h-12 w-12 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                </svg>
                <h3 class="mt-2 text-sm font-medium text-slate-300">No passwords stored</h3>
                <p class="mt-1 text-sm text-slate-500">Get started by creating a new password entry.</p>
                <div class="mt-6">
                    <button onclick="document.getElementById('addPasswordModal').classList.remove('hidden')" type="button" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary hover:bg-primaryHover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                        </svg>
                        New Password
                    </button>
                </div>
            </div>
        <% } %>
    </div>
</div>

<!-- Add Password Modal -->
<div id="addPasswordModal" class="fixed z-50 inset-0 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <!-- Background overlay -->
        <div class="fixed inset-0 bg-slate-900 bg-opacity-75 transition-opacity backdrop-blur-sm" aria-hidden="true" onclick="document.getElementById('addPasswordModal').classList.add('hidden')"></div>

        <!-- Center modal -->
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        <div class="inline-block align-bottom glass-panel rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-slate-700">
            <form action="<%= baseUrl %>/passwords/add" method="POST">
                <div class="px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-medium text-white mb-4" id="modal-title">Add New Password</h3>
                    <div class="space-y-4">
                        <div>
                            <label for="appName" class="block text-sm font-medium text-slate-300">Service/Website Name</label>
                            <input type="text" name="appName" id="appName" required
                                class="mt-1 block w-full rounded-md bg-slate-800 border-slate-600 text-white focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50 px-3 py-2 border shadow-sm">
                        </div>
                        <div>
                            <label for="appUsername" class="block text-sm font-medium text-slate-300">Username/Email</label>
                            <input type="text" name="appUsername" id="appUsername" required
                                class="mt-1 block w-full rounded-md bg-slate-800 border-slate-600 text-white focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50 px-3 py-2 border shadow-sm">
                        </div>
                        <div>
                            <label for="appPassword" class="block text-sm font-medium text-slate-300">Password</label>
                            <div class="mt-1 relative rounded-md shadow-sm">
                                <input type="password" name="appPassword" id="appPassword" required
                                    class="block w-full rounded-md bg-slate-800 border-slate-600 text-white focus:border-primary focus:ring focus:ring-primary focus:ring-opacity-50 px-3 py-2 border shadow-sm">
                                <button type="button" onclick="generatePassword()"
                                    class="absolute inset-y-0 right-0 px-3 flex items-center text-sm text-primary hover:text-primaryHover font-medium">
                                    Generate
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="px-4 py-3 border-t border-slate-700 sm:px-6 flex justify-end gap-3 bg-slate-800/30">
                    <button type="button" onclick="document.getElementById('addPasswordModal').classList.add('hidden')"
                        class="w-full inline-flex justify-center rounded-md border border-slate-600 shadow-sm px-4 py-2 bg-transparent text-base font-medium text-slate-300 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-500 sm:w-auto sm:text-sm transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                        class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary text-base font-medium text-white hover:bg-primaryHover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary sm:w-auto sm:text-sm transition-colors">
                        Save Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function togglePassword(inputId) {
        const input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
        } else {
            input.type = "password";
        }
    }

    function generatePassword() {
        const chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()_+~`|}{[]:;?><,./-=";
        let password = "";
        for (let i = 0; i < 16; i++) {
            password += chars.charAt(Math.floor(Math.random() * chars.length));
        }
        document.getElementById('appPassword').value = password;
        // make it text temporarily so user can see it
        document.getElementById('appPassword').type = "text";
        setTimeout(() => {
            document.getElementById('appPassword').type = "password";
        }, 5000); // hide after 5 seconds
    }
</script>

<%- include('partials/footer') %>
